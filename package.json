{
  "name": "seif-portfolio",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.5.3",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,md}\" \"*.md\" \"docs/**/*.md\" \".github/**/*.yml\" \"package.json\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,md}\" \"*.md\" \"docs/**/*.md\" \".github/**/*.yml\" \"package.json\"",
    "typecheck": "tsc --noEmit",
    "type-check": "tsc --noEmit",
    "verify": "npm run format:check && npm run lint:check && npm run typecheck && npm run build",
    "test": "vitest --passWithNoTests",
    "test:ui": "vitest --ui"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@react-three/fiber": "9.6.1",
    "clsx": "^2.1.1",
    "firebase-admin": "^14.2.0",
    "framer-motion": "^12.42.2",
    "lucide-react": "^1.17.0",
    "next": "16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "^7.78.0",
    "tailwind-merge": "^3.6.0",
    "three": "0.185.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "0.185.1",
    "eslint": "^9.39.4",
    "eslint-config-next": "16.2.10",
    "eslint-config-prettier": "^10.1.8",
    "happy-dom": "^20.10.2",
    "prettier": "^3.8.4",
    "tailwindcss": "^4",
    "typescript": "^5",
    "vitest": "^4.1.8"
  }
}
